# 应用配置
APP_NAME=PublicSentimentAnalysis
APP_VERSION=1.0.0
DEBUG=true

# 数据库（SQLite 单文件）
DATABASE_URL=sqlite:///./data/sentiment.db

# 日志
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 爬虫配置
CRAWLER_INTERVAL_MINUTES=60
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_MAX_RETRIES=3

# 数据保留
DATA_RETENTION_DAYS=30

# 情感分析模型
SENTIMENT_MODEL=bert-base-chinese
